{
  "compilerOptions": {
    "target": "ES2022",
    "types": ["node"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@utils/*": ["src/utils/*"]
    }
  },
  "include": ["src", "src/drills/**/*.ts", "src/drills/**/*/*.ts"]
}
